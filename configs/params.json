{
  "build": {
    "usbx": true,
    "motors": {
      "dji": true,
      "dm": true,
      "lk": false
    }
  },
  "bindings": {
    "remoter_uart": "uart5",
    "referee_uart": "usart1"
  },
  "can": {
    "fdcan1": {
      "id_type": "standard"
    },
    "fdcan2": {
      "id_type": "standard"
    },
    "fdcan3": {
      "id_type": "standard"
    }
  },
  "ahrs": {
